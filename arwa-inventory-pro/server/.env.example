# Server
PORT=4000

# Webhook secrets — paste from your aggregator dashboard
DELIVERECT_SECRET=your_deliverect_webhook_secret
OTTER_SECRET=your_otter_webhook_secret
DOORDASH_SECRET=your_doordash_webhook_secret
UBEREATS_SECRET=your_ubereats_webhook_secret

# CORS — your React app URL (dev + prod)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional: API key clients must send in ?key= query param
WS_API_KEY=arwa_dev_key
